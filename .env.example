SPREADSHEET_ID=1RIGHJlkxMDK53whMYGkNa-WbVwF9W__Oi9pB935s3YI
APPS_SCRIPT_URL=https://script.google.com/macros/s/your-deployment-id/exec
# Optional: server-side OAuth client ID for mobile (used to request idToken).
# Mobile picks up the client from google-services.json / Info.plist by default.
GOOGLE_SERVER_CLIENT_ID=
# Required for Flutter web Google Sign-In. Create a "Web application" OAuth
# client in Google Cloud Console and add your dev/prod origins to "Authorized
# JavaScript origins" (e.g. http://localhost:PORT, https://your.domain).
# Also paste this value into web/index.html (google-signin-client_id meta).
GOOGLE_WEB_CLIENT_ID=
